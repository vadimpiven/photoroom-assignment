{
  "name": "dag-ops",
  "version": "0.0.0",
  "description": "Node.js bindings for dag-ops - DAG-based f32 operations library",
  "license": "Apache-2.0 OR MIT",
  "author": "Vadim Piven <vadim@piven.tech> (https://piven.tech)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./export_dist/index.d.ts",
      "default": "./export_dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "type-check": "pnpm exec tsc --noEmit",
    "build:cargo": "cargo build && node ../../scripts/copy-addon.ts",
    "build:ts": "vite build && pnpm pack --out package.tar.gz",
    "build": "pnpm run build:cargo && pnpm run build:ts",
    "test:vitest": "pnpm exec vitest run --coverage",
    "test:ts": "pnpm run type-check && pnpm run test:vitest",
    "test:nextest": "node ../../scripts/test-nextest.ts",
    "test:rustdoc": "cargo doc --no-deps --document-private-items",
    "test:rust": "pnpm run test:nextest && pnpm run test:rustdoc",
    "pretest": "pnpm run build",
    "test": "pnpm run test:ts && pnpm run test:rust"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitest/coverage-istanbul": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "addon": {
    "path": "./dist/dag_ops_node.node"
  }
}
